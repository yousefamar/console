<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.Console" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
    </style>

    <style name="Theme.Console.Splash" parent="Theme.Console">
        <item name="android:windowSplashScreenBackground" tools:targetApi="31">@color/bg_dark</item>
        <item name="android:windowSplashScreenAnimatedIcon" tools:targetApi="31">@drawable/ic_splash</item>
        <item name="android:windowSplashScreenAnimationDuration" tools:targetApi="31">400</item>
    </style>

</resources>
